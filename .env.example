# openly — environment variables
# Copy this to .env.local and fill in your values

# Base URL (change for production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# X (Twitter) — get these from developer.x.com
X_API_KEY=
X_API_SECRET=

# LinkedIn — get these from linkedin.com/developers
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Cron secret — any random string to protect the /api/cron endpoint
CRON_SECRET=change-me-to-something-random
